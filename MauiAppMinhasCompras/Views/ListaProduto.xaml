<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.ListaProduto"
             Title="Minhas Compras">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Somar" Clicked="ToolbarItem_Clicked_1" />
        <ToolbarItem Text="Adicionar" Clicked="ToolbarItem_Clicked" />
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Label">
                <Setter Property="VerticalTextAlignment" Value="Center" />
            </Style>
            <Style x:Key="cabecalho_listview" TargetType="Grid">
                <Setter Property="BackgroundColor"
                        Value="{AppThemeBinding Light={StaticResource Gray100}, 
                                            Dark={StaticResource Primary}}" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <StackLayout>
        <SearchBar x:Name="txt_search"
                   Placeholder="Busca de Produtos"
                   TextChanged="txt_search_TextChanged">
            <SearchBar.Margin>
                <OnPlatform  x:TypeArguments="Thickness">
                    <On Platform="Android" Value="-15, 0, 0, 0" />
                    <On Platform="UWP" Value="5, 0, 5, 0" />
                </OnPlatform>
            </SearchBar.Margin>
        </SearchBar>

        <Frame Margin="10,0,10,10" Padding="5" BorderColor="{StaticResource Gray200}">
            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <Label Text="Categoria:" VerticalOptions="Center" FontAttributes="Bold" />
                <Picker x:Name="pck_categoria" 
                Title="Selecione"
                SelectedIndexChanged="pck_categoria_SelectedIndexChanged"
                WidthRequest="200">
                    <Picker.Items>
                        <x:String>Todos</x:String>
                        <x:String>Alimentos</x:String>
                        <x:String>Higiene</x:String>
                        <x:String>Limpeza</x:String>
                    </Picker.Items>
                </Picker>
            </HorizontalStackLayout>
        </Frame>

        <Frame Padding="0" Margin="10" VerticalOptions="FillAndExpand">
            <ListView x:Name="lst_produtos"
                  SelectionMode="None"
                  IsPullToRefreshEnabled="True"
                  Refreshing="lst_produtos_Refreshing"
                  ItemSelected="lst_produtos_ItemSelected">
                <ListView.Header>
                    <Grid ColumnDefinitions="30, 80, 80, 80, 50, 80" Style="{StaticResource cabecalho_listview}">
                        <Label Grid.Column="0" Text="Id" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="Categoria" FontAttributes="Bold" />
                        <Label Grid.Column="2" Text="Descrição" FontAttributes="Bold" />
                        <Label Grid.Column="3" Text="Preço" FontAttributes="Bold" />
                        <Label Grid.Column="4" Text="Qnt" FontAttributes="Bold" />
                        <Label Grid.Column="5" Text="Total" FontAttributes="Bold" />
                    </Grid>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <ViewCell.ContextActions>
                                <MenuItem Text="Remover" Clicked="MenuItem_Clicked" IsDestructive="True"/>
                            </ViewCell.ContextActions>
                            <Grid ColumnDefinitions="30, 80, 80, 80, 50, 80">
                                <Label Grid.Column="0" Text="{Binding Id}" />
                                <Label Grid.Column="1" Text="{Binding Categoria}" />
                                <Label Grid.Column="2" Text="{Binding Descricao}" />
                                <Label Grid.Column="3" Text="{Binding Preco, StringFormat='{}{0:c}'}" />
                                <Label Grid.Column="4" Text="{Binding Quantidade}" />
                                <Label Grid.Column="5" Text="{Binding Total, StringFormat='{}{0:c}'}" />
                            </Grid>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Frame>
    </StackLayout>
</ContentPage>