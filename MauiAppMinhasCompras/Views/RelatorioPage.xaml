<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.RelatorioPage"
             Title="Relatório de Gastos">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Voltar" Clicked="ToolbarItem_Clicked" />
    </ContentPage.ToolbarItems>

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Total por Categoria" 
               FontSize="22" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" />

        <CollectionView x:Name="lst_relatorio">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="15" BorderColor="{StaticResource Gray200}">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" 
                                   Text="{Binding Categoria}" 
                                   FontSize="Medium" 
                                   VerticalOptions="Center" />

                            <Label Grid.Column="1" 
                                   Text="{Binding TotalGeral, StringFormat='{0:C}'}" 
                                   TextColor="Green" 
                                   FontAttributes="Bold"
                                   FontSize="Medium" 
                                   VerticalOptions="Center" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>